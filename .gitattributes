# Normaliza line endings para LF no repositório; checkout em Windows usa CRLF
* text=auto

# Força LF para ficheiros de código e config (evita diff noise)
*.cpp    text eol=lf
*.h      text eol=lf
*.cmake  text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.txt    text eol=lf
*.mdc    text eol=lf

# Scripts Windows precisam de CRLF
*.bat    text eol=crlf

# Binários — sem conversão
*.png    binary
*.jpg    binary
*.exe    binary
*.dll    binary
*.vst3   binary
